{
  "manifest_version": 3,
  "name": "YUTH Browser Decision Support",
  "version": "0.1.0",
  "description": "Get YUTH spending guidance while browsing supported product pages.",
  "action": {
    "default_title": "Open YUTH Side Panel"
  },
  "permissions": ["activeTab", "storage", "sidePanel", "scripting"],
  "host_permissions": [
    "*://*.amazon.ca/*",
    "*://*.amazon.com/*",
    "*://*.bestbuy.ca/*",
    "*://*.sephora.ca/*",
    "*://*.sephora.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.ca/*",
        "*://*.amazon.com/*",
        "*://*.bestbuy.ca/*",
        "*://*.sephora.ca/*",
        "*://*.sephora.com/*"
      ],
      "js": ["config.js", "content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["app-user-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
